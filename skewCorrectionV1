def main():
    print("Loading:", INPUT_PLY)
    pcd = o3d.io.read_point_cloud(INPUT_PLY)
    pts = np.asarray(pcd.points)

    if len(pts) == 0:
        raise RuntimeError("PLY file contains no points")

    # Separate object vs floor
    object_mask = detect_floor_boundary(pts, GRID_RES)
    floor_pts = pts[~object_mask]

    if len(floor_pts) < 50:
        raise RuntimeError("Too few floor points for plane fitting")

    # Fit plane to floor
    a, b, c = fit_plane(floor_pts)
    print(f"Floor plane: z = {a:.6f}x + {b:.6f}y + {c:.6f}")

    # Plane subtraction
    z_plane = a * pts[:, 0] + b * pts[:, 1] + (c-shift)
    z_new = pts[:, 2] - z_plane

    # Clamp below-plane
    z_new[z_new < 0] = 0.0
    pts[:, 2] = z_new

    # --- REMOVE FLOOR POINTS HERE ---
    pts = pts[~object_mask]

